# NEXUS PROSPECT - CONFIGURAÇÃO LOCAL
# Copie este arquivo para .env.local e preencha com seus dados reais.

# Supabase (Frontend)
VITE_SUPABASE_URL=seu_projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# OpenAI (Backend/AI Agents)
OPENAI_API_KEY=sua_chave_openai_aqui

# Resend (Emails)
RESEND_API_KEY=sua_chave_resend_aqui

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://sua-api.com
EVOLUTION_API_KEY=seu_token_aqui

# Webhooks (N8N / Automations)
VITE_WEBHOOK_BASE_URL=https://nexus360.infra-conectamarketing.site/webhook
VITE_WEBHOOK_DISPATCHER_URL=https://n8n.com/xxx
VITE_WEBHOOK_PROXY_LEADS_URL=https://n8n.com/yyy
VITE_WEBHOOK_URL_CREATE_AGENT=https://n8n.com/create
VITE_WEBHOOK_URL_STATUS_AGENT=https://n8n.com/status
